VITE_SITE_URL=https://lovelight.cc

# Coming soon mode — set to true to show the launch splash and gate all public routes.
# Flip back to false (or remove) when ready to go live. Admin (/admin/*) always bypasses.
VITE_COMING_SOON=true

# Admin notification email for coming-soon sign-up alerts.
# Falls back to MAILGUN_REPLY_TO if left blank.
ADMIN_NOTIFY_EMAIL=hello@lovelight.cc

VITE_SUPABASE_URL=https://bxpfwhgbfadzsslqmaip.supabase.co
VITE_SUPABASE_KEY=sb_publishable_UWUgufW7hEonrcSSfAD28g_4MB10zwL

# YouTube Data API v3 — enables live artist/show search in the Header Design admin.
# Get a free key at console.cloud.google.com → APIs & Services → YouTube Data API v3.
# Restrict it to your site domain. Leave blank to use the "open YouTube" fallback.
VITE_YOUTUBE_API_KEY=

# Stripe — add these when ready (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
